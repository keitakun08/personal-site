---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About | Personal Site">
  <section class="py-12 md:py-20">
    <h1 class="text-4xl md:text-5xl font-bold text-brand-cobalt">About</h1>
  </section>

  <section class="py-8 space-y-6">
    <div class="grid-border p-6">
      <p class="text-gray-700 leading-relaxed">
        I'm a creative developer based in [Location] with a passion for building thoughtful digital experiences.
        My work sits at the intersection of design and engineering, where I focus on creating interfaces that
        are both beautiful and functional.
      </p>
    </div>

    <div class="grid-border p-6">
      <h2 class="text-sm uppercase tracking-widest text-gray-500 mb-4">Background</h2>
      <p class="text-gray-700 leading-relaxed">
        With [X] years of experience in frontend development, I've worked with startups and established companies
        to build products that matter. I specialize in React, TypeScript, and design systems.
      </p>
    </div>

    <div class="grid-border p-6">
      <h2 class="text-sm uppercase tracking-widest text-gray-500 mb-4">Currently</h2>
      <p class="text-gray-700 leading-relaxed">
        Working on design systems and exploring the boundaries of what's possible with modern web technologies.
        Always learning, always building.
      </p>
    </div>
  </section>
</Layout>