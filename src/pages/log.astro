---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allLog = await getCollection('log');
const sortedLog = allLog.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title="Log | Personal Site">
  <section class="py-12 md:py-20">
    <h1 class="text-4xl md:text-5xl font-bold text-brand-cobalt">Log</h1>
    <p class="mt-4 text-lg text-gray-600 max-w-xl">
      Short postcard-style updates from the日常 (daily life).
    </p>
  </section>

  <section class="py-8">
    <div class="space-y-6">
      {sortedLog.map((entry) => (
        <article class="grid-border p-6 hover:border-brand-cobalt/30 transition-colors">
          <time class="text-xs text-gray-500 uppercase tracking-wide">{entry.data.date}</time>
          <div class="mt-3 prose prose-sm max-w-none">
            <p class="text-gray-700">{entry.data.content}</p>
          </div>
        </article>
      ))}
    </div>
  </section>
</Layout>