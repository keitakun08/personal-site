---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Keita Eriawan"
  description="A personal portfolio and notebook by Keita Eriawan."
  pageTheme="home"
>
  <section class="page-shell home-page" aria-labelledby="home-title">
    <div class="home-copy">
      <p class="lead">
        <span class="hello">Hello.</span>
        I’m <span class="name" id="home-title">Keita Eriawan</span>, a curious practitioner using
        <span class="keyword keyword-data" aria-label="data">
          <span>d</span><span>a</span><span>t</span><span>a</span>
        </span>,
        <span class="keyword keyword-code" aria-label="code">
          <span aria-hidden="true">[</span><span>code</span><span class="code-cursor" aria-hidden="true">_</span><span aria-hidden="true">]</span>
        </span>,
        and
        <span class="keyword keyword-curiosity" aria-label="curiosity">
          <span>c</span><span>u</span><span>r</span><span>i</span><span>o</span><span>s</span><span>i</span><span>t</span><span>y</span>
        </span>
        to explore messy questions and build useful things along the way.
      </p>
      <p class="lead">
        This is where I share projects, experiments, and what I learn while building them.
      </p>
    </div>
  </section>
</Layout>
