---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Keita Eriawan"
  description="A personal portfolio and notebook by Keita Eriawan."
  pageTheme="home"
>
  <section class="page-shell home-page" aria-labelledby="home-title">
    <div class="home-copy">
      <p class="lead">
        <span class="hello">Hello.</span>
        I’m <span class="name" id="home-title">Keita Eriawan</span>, a data practitioner building a small public notebook for projects, practical analysis, and useful decisions.
      </p>
      <p class="lead">
        I’m interested in places where messy information is <span class="type-break">reshaping</span> how people work, learn, and make choices.
      </p>
      <p class="lead"><span class="marker">~/</span> It’s nice to meet you.</p>
    </div>
  </section>
</Layout>
