---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Keita Eriawan"
  description="A personal portfolio and notebook by Keita Eriawan."
  pageTheme="home"
>
  <section class="page-shell home-page" aria-labelledby="home-title">
    <div class="home-copy">
      <p class="lead">
        <span class="hello">Hello.</span>
        <span id="home-title">I’m Keita.</span> I use data, code, and <span class="name">curiosity</span> to explore messy questions and build useful things along the way.
      </p>
      <p class="lead">
        This is where I share projects, experiments, and what I learn while building them.
      </p>
    </div>
  </section>
</Layout>
