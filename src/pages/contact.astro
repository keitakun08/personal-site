---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact | Keita Eriawan"
  description="Contact Keita Eriawan."
  pageTheme="about"
>
  <section class="page-shell" aria-labelledby="contact-title">
    <div class="page-grid">
      <aside class="page-label">
        <span>04</span>
        <strong id="contact-title">Contact</strong>
        <span>Legacy route</span>
      </aside>

      <div class="about-layout">
        <article class="about-panel">
          <h1>Let’s connect.</h1>
          <p>
            This route is kept for old links. The main site now keeps contact details
            inside the About page.
          </p>
        </article>

        <article class="about-panel">
          <div class="meta">
            <span>Email</span>
            <span>Open</span>
          </div>
          <p>
            Replace this temporary address with the email or profile link you want visitors to use.
          </p>
          <a class="contact-pill" href="mailto:hello@example.com">Email me</a>
        </article>
      </div>
    </div>
  </section>
</Layout>
