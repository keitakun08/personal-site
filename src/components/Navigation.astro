---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home', matches: ['/'] },
  { href: '/project', label: 'Project', matches: ['/project', '/work'] },
  { href: '/blog', label: 'Blog', matches: ['/blog', '/log'] },
  { href: '/about', label: 'About', matches: ['/about', '/contact'] },
];

const activeLink = navLinks.find((link) =>
  link.matches.some((match) =>
    match === '/' ? currentPath === '/' : currentPath.startsWith(match)
  )
);
---

<header class="site-header">
  <nav class="site-nav" aria-label="Primary navigation">
    {
      navLinks.map((link) => (
        <a
          href={link.href}
          aria-current={activeLink?.href === link.href ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))
    }
  </nav>
  <div class="site-status" aria-label="Local status">
    <strong>00:22</strong>
    <span>Good night</span>
  </div>
</header>
